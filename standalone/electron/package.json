{
  "name": "auma-app",
  "private": true,
  "version": "0.1.0",
  "description": "AudIA Mastering Assistant — Electron + React frontend",
  "license": "GPL-3.0-only",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && AUMA_DEV=1 electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:web": "vite build",
    "build": "npm run build:web && npm run build:electron",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^30.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
